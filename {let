<script>let ws;function connect({let name=document.getElementById('name'.value;if(!name)return;ws=new WebSocket(`ws://${window.location.hostname}:8000/ws/${name}`);ws.onopen=()==false;alert('Connected!');};ws.onmessage=e= chat=document.getElementById('chat';chat.innerHTML+=`<div>${e.data}</div>`;chat.scrollTop=chat.scrollHeight;};}function send({let msg=document.getElementById('msg'.value;if(ws)ws.send(msg);document.getElementById('msg'.value='';}</script>
